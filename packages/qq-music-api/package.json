{
  "name": "qq-music-api",
  "version": "2.2.8",
  "publishConfig": {
    "access": "public"
  },
  "description": "QQ Music API - Refactored Pure JS SDK",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm exec tsc",
    "lint": "npm exec tsc -- --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "record:fixtures": "tsx tests/recordFixtures.ts",
    "test:replay": "tsx --test tests/replay.test.ts",
    "test:unit": "tsx --test tests/index.test.ts tests/controllers.test.ts tests/util.test.ts",
    "test:integration": "tsx --test tests/integration.test.ts"
  },
  "keywords": [
    "QQ 音乐",
    "音乐",
    "qq-music-api"
  ],
  "author": "sansenjian",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "date-fns": "^4.1.0",
    "is-generator-function": "1.0.10",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
